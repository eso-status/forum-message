{
  "name": "@eso-status/forum-message",
  "version": "2.0.0-dev.24",
  "description": "Library for retrieving and formatting data, available at https://forums.elderscrollsonline.com or https://forums.elderscrollsonline.com/en/categories/pts",
  "author": "@dov118 <contact.dov118.dev@gmail.com> (https://dov118.dev)",
  "main": "lib/index.js",
  "license": "MIT",
  "engineStrict": true,
  "files": [
    "lib/",
    ".npmrc,",
    "LICENSE.md",
    "package.json",
    "README.md"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "bugs": {
    "url": "https://github.com/eso-status/forum-message/issues"
  },
  "homepage": "https://github.com/eso-status/forum-message#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:eso-status/forum-message.git"
  },
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "build": "rm -R -f lib/* && tsc --project tsconfig.build.json",
    "dev": "npm run build && node .",
    "watch": "nodemon --exec npm run dev",
    "test": "npm run build && jest --config jest.config.ts --runInBand",
    "test:watch": "jest --config jest.config.ts --runInBand --watch",
    "test:cov": "jest --config jest.config.ts --runInBand --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@eso-status/types": "2.0.0-dev.20",
    "axios": "1.14.0",
    "moment": "2.30.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.1",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "lint-staged": "16.4.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.1",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  }
}
